generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
 
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  provider  String
  createdAt DateTime @default(now())
  urls      Url[]
}

model Url {
  id        String   @id @default(uuid())
  original  String
  short     String   @unique
  clicks    Int      @default(0)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}